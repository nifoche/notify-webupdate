# SNS Monitoring Configuration - 31sumai Edition

# Target URL (31sumai model room reservation page)
TARGET_URLS=https://www.31sumai.com/attend/X2571/

# Check interval in seconds (recommended: 60-300 for 31sumai)
CHECK_INTERVAL=60

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_USER_ID=your_user_id

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=your_email@gmail.com
TO_EMAIL=recipient@example.com

# Database path
DATABASE_PATH=posts.db

# Logging
LOG_PATH=monitor.log
LOG_LEVEL=INFO
